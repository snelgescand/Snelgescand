// Prisma-schema voor Sportief Opgewekt API.
//
// Multi-tenant model:
//   - Een `Tenant` is een adviesbureau of zelfstandig adviseur.
//   - `User` hoort bij één tenant, kan meerdere rollen hebben.
//   - `Project` is een verduurzamingsplan voor één sportclub.
//   - Alle queries vanuit de API filteren op req.user.tenantId.
//
// State van een project:
//   - `state` JSONB bevat het volledige ProjectContext + alle gekozen
//     maatregel-inputs. Single source of truth.
//   - `cachedResult` JSONB bevat de laatste rollup-output voor snelle reads.
//     Wordt nullified bij elke state-mutatie en herberekend on-demand.
//   - `timeseries` aparte tabel met BYTEA Float32Array — alleen geladen
//     als de batterij-tijdreeks-view geopend wordt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  naam        String
  slug        String   @unique         // gebruikt in URL: /t/{slug}/...
  domein      String?  @unique         // optionele eigen domeinnaam
  branding    Json?                    // logo-url, kleuren — null = default branding
  /// Berekening-instellingen: prijzen, vuistregels, subsidies.
  /// Wordt gebruikt als default bij het aanmaken van nieuwe projecten
  /// en in de PPT-template-export.
  /// Schema: { prijzen: { gasPerM3, stroomPerKwh, waterPerM3 }, vuistregels: { ... }, subsidies: { ... } }
  instellingen Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  projects    Project[]
  factuurReferenties FactuurReferentie[]

  @@index([slug])
}

enum UserRol {
  ADVISEUR
  BEHEERDER
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  naam          String
  rol           UserRol  @default(ADVISEUR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  laatsteLogin  DateTime?

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projecten     Project[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  AFGEROND
  GEARCHIVEERD
}

model Project {
  id              String   @id @default(cuid())
  tenantId        String
  eigenaarId      String

  clubNaam        String
  status          ProjectStatus @default(DRAFT)
  postcode        String?
  huisnummer      String?

  // De volledige invoer (ProjectContext + maatregel-inputs)
  state           Json

  // Cache van laatste rollup-output. NULL = stale.
  cachedResult    Json?
  cachedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eigenaar        User     @relation(fields: [eigenaarId], references: [id])

  timeseries      Timeseries[]
  pptExports      PptExport[]

  @@index([tenantId, status])
  @@index([eigenaarId])
}

// 8760-uur tijdreeksen voor de batterij-engine.
// Opgeslagen als Float32Array → bytes (4 byte × 8760 = ~35 KB per serie).
model Timeseries {
  id          String   @id @default(cuid())
  projectId   String
  soort       String   // 'pv-productie' | 'verbruik' | 'epex-prijs' | 'soc' | ...
  jaar        Int
  data        Bytes
  metaJson    Json?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, soort, jaar])
  @@index([projectId])
}

enum PptStatus {
  WACHTEND
  BEZIG
  KLAAR
  MISLUKT
}

// Async PPT-export jobs (gegenereerd via python-pptx sidecar).
model PptExport {
  id           String   @id @default(cuid())
  projectId    String
  status       PptStatus @default(WACHTEND)
  filePath     String?
  fileSizeBytes Int?
  foutmelding  String?
  createdAt    DateTime @default(now())
  klaarOp      DateTime?

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

// Cache voor externe API-calls (BAG/PDOK/EPEX) zodat we niet bij elke
// projectview opnieuw bevragen.
model ExternalCache {
  id          String   @id @default(cuid())
  provider    String   // 'bag' | 'pdok' | 'epex' | 'entso-e'
  key         String   // bv. postcode+huisnr, of datum-bereik
  data        Json
  vervaltOp   DateTime
  createdAt   DateTime @default(now())

  @@unique([provider, key])
  @@index([provider, vervaltOp])
}

// FactuurReferentie — referentie-bedragen uit eerdere offertes/facturen.
// Tekst-only (geen PDF-uploads), per tenant afgeschermd. Adviseurs kunnen
// lezen, alleen BEHEERDERS kunnen aanmaken/bewerken/verwijderen.
//
// Bedoeld als interne kennisbank: "wat kostte een Q-ton HMA30A in 2024 ongeveer?"
// → snel raadplegen zonder een PDF op te zoeken.
model FactuurReferentie {
  id           String   @id @default(cuid())
  tenantId     String
  /// Categorie: 'qton', 'lmnt', 'pv', 'isolatie-dak', 'veldverlichting', etc.
  /// Vrije tekst zodat we niet steeds een enum hoeven uit te breiden.
  categorie    String
  /// Leverancier-naam, bv. "Mitsubishi via installateur Y"
  leverancier  String
  /// Jaar van de offerte/factuur — voor inschatting van prijspeil
  jaar         Int
  /// Bedrag in hele euro's, incl. btw (kies één conventie consistent)
  bedrag       Int
  /// Korte toelichting: capaciteit/vermogen, locatie-type, enz.
  /// bv. "30 kW HMA30A incl. 1000L buffer, voetbalclub 250 leden"
  toelichting  String?
  /// Wie heeft 'm ingevoerd (BEHEERDER-userId)
  invoerderId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, categorie])
  @@index([tenantId, jaar])
}
