# Kopieer naar .env en pas aan.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres (zie docker-compose.yml voor lokale setup)
DATABASE_URL="postgresql://sopg:lokaal_alleen@localhost:5432/sportief_opgewekt?schema=public"
REDIS_URL="redis://localhost:6379"

# Beide minimaal 32 tekens; genereer met:  openssl rand -hex 32
JWT_SECRET="vervang-mij-met-32-of-meer-tekens-van-random-bytes"
COOKIE_SECRET="vervang-mij-ook-met-32-of-meer-tekens-van-random"

# Optioneel: alleen zetten als je een eigen domein hebt
# COOKIE_DOMAIN=.sportief-opgewekt.nl

ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Eenmalige seed (gebruikt door pnpm seed)
SEED_TENANT_NAAM="Snelgescand"
SEED_TENANT_SLUG=snelgescand
SEED_ADMIN_EMAIL=bart@snelgescand.nl
SEED_ADMIN_PASSWORD=sportief123

# Optioneel
# ENTSO_E_API_TOKEN=xxxx
